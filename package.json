{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Projeto de clone do tabnews.com.br, feito no curso.dev do Filipe Deschamps",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npm run docker:up && npm run wait-for-postgress && npm run migration:up && next dev",
    "dev:next": "next dev",
    "teste": "jest --runInBand",
    "teste:watch": "jest --runInBand --watchAll",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "docker:up": "docker compose -f infra/compose.yaml up -d",
    "docker:stop": "docker compose -f infra/compose.yaml stop",
    "docker:down": "docker compose -f infra/compose.yaml down",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "wait-for-postgress": "node infra/scripts/wait-for-postgres.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv-expand": "^12.0.3",
    "eslint-config-next": "^16.1.6",
    "next": "^16.1.6",
    "pg": "^8.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.9.1",
    "prettier": "^3.5.3"
  }
}
